PORT=3001
MODEL_PROVIDER=mock
# 腾讯混元角色扮演模型（推荐用于本项目）
# MODEL_PROVIDER=hunyuan
# HUNYUAN_API_KEY=your-tokenhub-api-key
# HUNYUAN_BASE_URL=https://tokenhub.tencentmaas.com/v1
# HUNYUAN_MODEL=hunyuan-role-latest

# 使用 GPT-5.5 时改为 openai。API Key 只能放在服务端，不能写进 client。
# MODEL_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5.5
# 游戏动态剧情优先低延迟；可选 none / low / medium / high / xhigh。
# LLM_REASONING_EFFORT=low
# LLM_TIMEOUT_MS=45000
# Clash 等本地 HTTP 代理；不需要填写机场订阅或上游节点 URL。
# LLM_PROXY_URL=http://127.0.0.1:7890
